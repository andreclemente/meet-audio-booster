{
  "manifest_version": 3,
  "name": "Meet Audio Booster",
  "version": "1.2.1",
  "description": "Per-participant volume controls for Google Meet and Jitsi Meet.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://meet.jit.si/*"
  ],
  "action": {
    "default_title": "Show Meet Audio Booster"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://meet.jit.si/*"
      ],
      "js": [
        "audio-booster.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
